FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      fvModels;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "${FOAM_CASE}/constant/globalVars"

massSource
{
    type            massSource;

//    selectionMode   cellZone;
//    cellZone        injection;

    selectionMode   points;
    points
    (
        ($x1 0.002 $z1)
        ($x2 0.002 $z2)
        ($x3 0.002 $z3)
        ($x4 0.002 $z4)
	($x1neg 0.002 $z1)
        ($x2neg 0.002 $z2)
        ($x3neg 0.002 $z3)
	($x1 0.002 $z1neg)
        ($x2 0.002 $z2neg)
        ($x3 0.002 $z3neg)
        ($x4 0.002 $z4neg)
	($x1neg 0.002 $z1neg)
        ($x2neg 0.002 $z2neg)
        ($x3neg 0.002 $z3neg)

    );

    massFlowRate    $M_flowRate;
    phase           gas;
    rho             thermo:rho.gas;

    fieldValues
    {
        U.gas     (0 0 0);
        O2.gas  0.23;
        H2O.gas  0;
    }
}

baseSource
{
    type            massSource;

    selectionMode   points;
    points
    (
        (-0.035 0 0)
    );

    massFlowRate    $base_flowRate;
    phase           liquid;
    rho             thermo:rho.liquid;

    fieldValues
    {
        U.liquid     (0 0 0);
        NH3.liquid   0.3;
    }
}

